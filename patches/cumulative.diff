+heirloom_darwin_stub_trap(const char *sym)
+{
+	fprintf(stderr,
+	    "pkg: '%s' not supported on this Darwin build "
+	    "(signed-package/web-install disabled — see PORT.md)\n",
+	    sym);
+	errno = ENOTSUP;
+	return -1;
+}
