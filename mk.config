#
# Path to the Heirloom Bourne shell. It is used during compilation
# as well as by the package commands.
#
SHELL = /opt/heirloom/bin/sh

#
# A BSD-compatible install command.
#
INSTALL=/usr/bin/install

#
# Where the Heirloom Development Tools package has been placed.
# $(CCSDIR)/bin must also be in the PATH setting when building.
#
CCSDIR=/opt/heirloom/ccs

#
# Prefixes.
#
PREFIX=/opt/heirloom
VAR=/opt/heirloom/var

#
# Where to place binaries. This must be the same place
# where the Heirloom Toolchest binaries are installed.
#
BINDIR=$(PREFIX)/bin

#
# Where to place superuser-only binaries. This may be
# the same place as the binary directory.
#
SBINDIR=$(PREFIX)/bin

#
# Where to place configuration files.
#
ETCDIR=$(PREFIX)/etc

#
# Where to place (read-only) helper files.
#
SADMDIR=$(PREFIX)/sadm

#
# Where to place the database of installed packages.
#
VSADMDIR=$(VAR)/sadm

#
# Where to place manual pages.
#
MANDIR=$(PREFIX)/share/man/5man

#
# Binaries are stripped with this command after installation.
#
STRIP=strip

#
# Compiler flags.
#
CFLAGS=-O -g

#
# C preprocessor flags.
#
# Use -D_GNU_SOURCE for Linux with GNU libc.
# Use -D_INCLUDE__STDC_A1_SOURCE for HP-UX.
#
HDRS=/Volumes/heirloom/src/pkgtools/hdrs
CPPFLAGS=-D_DARWIN_C_SOURCE -include $(HDRS)/darwin_stat_shim.h -I$(HDRS) -I/opt/homebrew/opt/openssl@3/include

#
# LIBS carries the OpenSSL 3.x runtime for pkgcmd linking. Referenced
# via $(LIBS) in each pkgcmd's Makefile.mk. -- Heirloom Darwin port
# (Phase 5-C4).
#
LIBS=-L/opt/homebrew/opt/openssl@3/lib -lssl -lcrypto

#
# scriptvfy.l uses Bell Labs lex internals (yytchar, yysptr, yysbuf, U())
# that flex does not emit. Point LEX at the Heirloom-devtools lex which
# preserves the Bell Labs lineage. -- Heirloom Darwin port.
#
LEX=/opt/heirloom/ccs/bin/lex

#
# Warning flags for the compiler.
#
WARN=

#
# Linker flags.
#
LDFLAGS=

#
# Additional libraries to link with.
#
LIBS=

#
# It may be necessary to define AR on some systems, e.g. on HP-UX.
#
#AR=ar

#
# Run ranlib if it is in the current path. This should take care
# of most situations. On Mac OS X, you need to uncomment "ranlib -c".
#
#RANLIB=(hash ranlib) >/dev/null 2>&1 || exit 0; ranlib
RANLIB=ranlib -c

#
# Use this if you prefer hard links between installed files.
#
LNS = ln -s

#
# Do not modify anything below here.
#
PATHS = \
	-DSHELL='"$(SHELL)"' \
	-DETCDIR='"$(ETCDIR)"' \
	-DBINDIR='"$(BINDIR)"' \
	-DSBINDIR='"$(SBINDIR)"' \
	-DSADMDIR='"$(SADMDIR)"' \
	-DVSADMDIR='"$(VSADMDIR)"' \
	-DVSADMREL='"$(VSADMDIR:/%=%)"'
